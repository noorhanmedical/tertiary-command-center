# =============================================================================
# Plexus Ancillary Screening — environment variables
# Copy this file to `.env` (development) or load values into Secrets Manager
# (production). Variables marked REQUIRED-PROD are enforced at startup when
# NODE_ENV=production.
# =============================================================================

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
# Bound port. ECS task definition should map this to the ALB target group.
PORT=5000

# ─── Database (REQUIRED) ────────────────────────────────────────────────────
# Postgres connection string. In AWS, point at RDS Postgres.
# Example: postgres://app:password@plexus-prod.xxxxx.us-east-1.rds.amazonaws.com:5432/plexus?sslmode=require
DATABASE_URL=postgres://localhost:5432/plexus

# ─── Session (REQUIRED) ─────────────────────────────────────────────────────
# Long random string. Rotating this invalidates all sessions.
SESSION_SECRET=replace-me-with-a-long-random-string

# ─── Document storage (REQUIRED-PROD: must be `s3` in production) ───────────
# Allowed values: s3 | google_drive
# In production the app refuses to start unless this is set to `s3`. The
# `google_drive` provider remains available for development.
STORAGE_PROVIDER=google_drive

# ─── AWS / S3 (REQUIRED-PROD when STORAGE_PROVIDER=s3) ──────────────────────
# In ECS Fargate, prefer attaching an IAM task role and leaving AWS_ACCESS_KEY_ID
# / AWS_SECRET_ACCESS_KEY unset — the AWS SDK will pick up the role automatically.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=plexus-documents

# ─── OpenAI / AI integrations (required for note generation) ────────────────
# When using Replit AI integrations these are injected automatically; for AWS
# deploys, set them to your OpenAI API key and (optionally) a custom base URL.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional: cap concurrent OpenAI requests across the process.
OPENAI_MAX_CONCURRENT=10

# ─── Google Sheets / Drive (used for billing + patient sync, optional) ──────
# Service-account JSON (single-line string). Only required if you keep the
# Google Sheets sync features enabled in production.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Drive root folder ID (used by the Drive provider only — not S3).
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Pinned spreadsheet IDs (will be created on first sync if unset).
GOOGLE_SHEETS_PATIENTS_ID=
GOOGLE_SHEETS_BILLING_ID=
